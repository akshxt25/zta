# Copy to .env and fill in values (never commit .env)

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/zero-trust

# JWT — use a long random string (32+ characters)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Gmail (app password) for OTP emails
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Server
PORT=5000
NODE_ENV=development

# Behind nginx / load balancer: number of trusted hops (e.g. 1). Default 0 = do not trust X-Forwarded-For
TRUST_PROXY_HOPS=0

# Optional: comma-separated allowed browser origins for CORS (omit for permissive dev)
# CORS_ORIGIN=http://localhost:3000,https://app.example.com
